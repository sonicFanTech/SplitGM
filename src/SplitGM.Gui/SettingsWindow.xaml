<Window x:Class="SplitGM.Gui.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SplitGM Settings" Width="620" Height="610" MinWidth="560" MinHeight="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{StaticResource WindowBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="SplitGM Settings" FontSize="23" FontWeight="Bold"/>
            <TextBlock Text="Settings are saved to SplitGM_Settings.ini." Margin="0,4,0,0"
                       Foreground="{StaticResource MutedTextBrush}"/>
        </StackPanel>
        <TabControl Grid.Row="1">
            <TabItem Header="General">
                <StackPanel Margin="16">
                    <CheckBox x:Name="ConfirmOverwriteCheckBox" Content="Confirm before overwriting an existing SplitGM output" Margin="0,0,0,12"/>
                    <CheckBox x:Name="OpenOutputCheckBox" Content="Open the output folder after a successful export" Margin="0,0,0,12"/>
                    <CheckBox x:Name="ShowOperationWindowCheckBox" Content="Show the detailed loading/export progress window" Margin="0,0,0,12"/>
                    <CheckBox x:Name="AutoCloseOperationWindowCheckBox" Content="Automatically close the operation window after success" Margin="0,0,0,18"/>
                    <TextBlock Text="Default export directory" FontWeight="SemiBold"/>
                    <Grid Margin="0,6,0,18">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="DefaultExportDirectoryTextBox"/>
                        <Button Grid.Column="1" Content="Browse..." Margin="8,0,0,0" Click="BrowseExportDirectory_Click"/>
                    </Grid>
                    <TextBlock Text="Maximum relationship results" FontWeight="SemiBold"/>
                    <TextBox x:Name="RelationshipLimitTextBox" Width="140" HorizontalAlignment="Left" Margin="0,6,0,0"/>
                    <TextBlock Text="Higher values can take longer on very large games. Range: 100–10,000."
                               Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Display">
                <StackPanel Margin="16">
                    <CheckBox x:Name="LineNumbersCheckBox" Content="Show line numbers in GML and VM assembly" Margin="0,0,0,12"/>
                    <CheckBox x:Name="WordWrapCheckBox" Content="Wrap long lines in code viewers" Margin="0,0,0,12"/>
                    <CheckBox x:Name="RememberWindowCheckBox" Content="Remember the main window size and position" Margin="0,0,0,12"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Export Defaults">
                <StackPanel Margin="16">
                    <CheckBox x:Name="ExportResourcesCheckBox" Content="Extract recoverable resources" Margin="0,0,0,12"/>
                    <CheckBox x:Name="ExportAssemblyCheckBox" Content="Export VM assembly alongside GML" Margin="0,0,0,12"/>
                    <CheckBox x:Name="ExportIndexesCheckBox" Content="Export JSON resource indexes" Margin="0,0,0,12"/>
                    <TextBlock Text="These defaults are used by Export Full Project. They can be changed here at any time."
                               TextWrapping="Wrap" Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="File">
                <StackPanel Margin="16">
                    <TextBlock Text="Settings file" FontWeight="SemiBold"/>
                    <TextBox x:Name="SettingsPathTextBox" IsReadOnly="True" Margin="0,6,0,12" TextWrapping="Wrap"/>
                    <Button Content="Open settings folder" HorizontalAlignment="Left" Click="OpenSettingsFolder_Click"/>
                </StackPanel>
            </TabItem>
        </TabControl>
        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Cancel" Click="Cancel_Click"/>
            <Button Grid.Column="2" Content="Save" Margin="0" Background="#155A74" BorderBrush="{StaticResource AccentBrush}" Click="Save_Click"/>
        </Grid>
    </Grid>
</Window>
