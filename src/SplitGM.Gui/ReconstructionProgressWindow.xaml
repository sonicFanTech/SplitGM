<Window x:Class="SplitGM.Gui.ReconstructionProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SplitGM Reconstructed .yyp Export"
        Width="1120" Height="760" MinWidth="900" MinHeight="620"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Icon="Resources/Brand/SplitGM.ico"
        Background="{StaticResource WindowBrush}" Closing="Window_Closing">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Image Source="Resources/Brand/SplitGM_programLogo.png" Width="58" Height="58"
                   Stretch="Uniform" Margin="0,0,14,0"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Decompile to Reconstructed .yyp Project"
                           FontSize="24" FontWeight="Bold"/>
                <TextBlock x:Name="DescriptionText" Margin="0,4,0,0" TextWrapping="Wrap"
                           Foreground="{StaticResource MutedTextBrush}"/>
            </StackPanel>
            <Border Grid.Column="2" Padding="11,7" VerticalAlignment="Center"
                    Background="#19243A" BorderBrush="{StaticResource Accent2Brush}" BorderThickness="1">
                <TextBlock Text="v0.5.0 PROJECT RECONSTRUCTION"
                           Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
            </Border>
        </Grid>

        <Border Grid.Row="1" Margin="0,14,0,12" Padding="12"
                Background="{StaticResource PanelAltBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="85"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Output" Foreground="{StaticResource MutedTextBrush}"/>
                <TextBlock x:Name="OutputPathText" Grid.Column="1" Grid.ColumnSpan="3" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="1" Text="Stage" Margin="0,6,0,0"
                           Foreground="{StaticResource MutedTextBrush}"/>
                <TextBlock x:Name="StageText" Grid.Row="1" Grid.Column="1" Margin="0,6,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Elapsed" Margin="12,6,0,0"
                           Foreground="{StaticResource MutedTextBrush}"/>
                <TextBlock x:Name="ElapsedText" Grid.Row="1" Grid.Column="3" Margin="0,6,0,0"/>
                <ProgressBar x:Name="ExportProgressBar" Grid.Row="2" Grid.ColumnSpan="4"
                             Height="12" Margin="0,10,0,0" Minimum="0" Maximum="100"
                             Foreground="{StaticResource AccentBrush}" Background="#080B11"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Padding="12" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Current resource" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource Accent2Brush}"/>
                    <Border Grid.Row="1" Margin="0,10,0,10" Background="#080B10"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Grid>
                            <Image x:Name="ResourcePreviewImage" Stretch="Uniform" Margin="8"/>
                            <TextBox x:Name="ResourcePreviewTextBox" Visibility="Collapsed"
                                     IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                     Background="Transparent" BorderThickness="0" Padding="10"
                                     FontFamily="Consolas" FontSize="12"/>
                            <TextBlock x:Name="NoPreviewText" Text="Waiting for a displayable resource..."
                                       TextAlignment="Center" TextWrapping="Wrap"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24"/>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="2">
                        <TextBlock x:Name="CurrentResourceText" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        <TextBlock x:Name="CurrentOutputText" Margin="0,4,0,0" TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Padding="12" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Resources being exported" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource Accent2Brush}"/>
                        <TextBlock x:Name="ResourceCountText" Grid.Column="1"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </Grid>
                    <DataGrid x:Name="ResourceGrid" Grid.Row="1" Margin="0,10,0,0"
                              AlternationCount="2" EnableRowVirtualization="True"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="95"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="120"/>
                            <DataGridTextColumn Header="Resource" Binding="{Binding Name}" Width="220"/>
                            <DataGridTextColumn Header="Output" Binding="{Binding Output}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Margin="0,12,0,0" Padding="10"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ProgressMessageText" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <TextBlock x:Name="ProgressCountText" Grid.Column="1" Margin="12,0,0,0"
                               Foreground="{StaticResource MutedTextBrush}"/>
                </Grid>
                <TextBox x:Name="ExportLogTextBox" Grid.Row="1" Margin="0,8,0,0"
                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         Background="{StaticResource EditorBrush}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="CompletionText" VerticalAlignment="Center" TextWrapping="Wrap"
                       Foreground="{StaticResource MutedTextBrush}"/>
            <Button x:Name="CancelExportButton" Grid.Column="1" Content="Cancel export" Click="Cancel_Click"/>
            <Button x:Name="CloseButton" Grid.Column="2" Content="Close" Margin="0"
                    IsEnabled="False" Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>
