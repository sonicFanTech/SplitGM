<Window x:Class="SplitGM.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SplitGM.Gui"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="SplitGM-VM Decompiler v0.4.0"
        Width="1460" Height="900" MinWidth="1080" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBrush}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Closing="Window_Closing" KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="#0B1018" Foreground="{StaticResource TextBrush}">
            <MenuItem Header="_File">
                <MenuItem x:Name="OpenGameButton" Header="_Open game..." InputGestureText="Ctrl+O" Click="OpenGameButton_Click"/>
                <MenuItem x:Name="OpenLastGameMenuItem" Header="Open _last game" IsEnabled="False" Click="OpenLastGameMenuItem_Click"/>
                <Separator/>
                <MenuItem x:Name="CloseGameButton" Header="_Close game" IsEnabled="False" Click="CloseGameButton_Click"/>
                <MenuItem x:Name="OpenOutputButton" Header="Open last _output" IsEnabled="False" Click="OpenOutputButton_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Copy current view" InputGestureText="Ctrl+Shift+C" Click="CopyCurrentViewButton_Click"/>
                <MenuItem Header="Copy _diagnostic report" Click="CopyDiagnosticButton_Click"/>
            </MenuItem>
            <MenuItem Header="_Export">
                <MenuItem x:Name="ExportButton" Header="Export _full reconstructed project..." IsEnabled="False" Click="ExportButton_Click"/>
                <MenuItem x:Name="ExportSelectedButton" Header="Export _selected resource..." IsEnabled="False" Click="ExportSelectedButton_Click"/>
                <MenuItem x:Name="ExportAudioGroupMenuItem" Header="Export selected _audio group..." IsEnabled="False" Click="ExportAudioGroupButton_Click"/>
                <Separator/>
                <MenuItem x:Name="ExportResourceTypeMenuItem" Header="Export complete _resource type" IsEnabled="False">
                    <MenuItem Header="_Graphics">
                        <MenuItem Header="All _sprites..." Tag="Sprites" Click="ExportResourceTypeMenuItem_Click"/>
                        <MenuItem Header="All _backgrounds / tilesets..." Tag="Backgrounds" Click="ExportResourceTypeMenuItem_Click"/>
                        <MenuItem Header="All _fonts..." Tag="Fonts" Click="ExportResourceTypeMenuItem_Click"/>
                        <Separator/>
                        <MenuItem Header="All texture _pages..." Tag="TexturePages" Click="ExportResourceTypeMenuItem_Click"/>
                        <MenuItem Header="All texture-page _items..." Tag="TexturePageItems" Click="ExportResourceTypeMenuItem_Click"/>
                        <MenuItem Header="All _embedded images..." Tag="EmbeddedImages" Click="ExportResourceTypeMenuItem_Click"/>
                    </MenuItem>
                    <MenuItem Header="_Audio">
                        <MenuItem Header="All _sounds..." Tag="Sounds" Click="ExportResourceTypeMenuItem_Click"/>
                        <MenuItem Header="All audio _groups..." Tag="AudioGroups" Click="ExportResourceTypeMenuItem_Click"/>
                        <MenuItem Header="All _embedded audio..." Tag="EmbeddedAudio" Click="ExportResourceTypeMenuItem_Click"/>
                    </MenuItem>
                    <MenuItem Header="_Rooms and objects">
                        <MenuItem Header="All _rooms..." Tag="Rooms" Click="ExportResourceTypeMenuItem_Click"/>
                        <MenuItem Header="All _objects..." Tag="Objects" Click="ExportResourceTypeMenuItem_Click"/>
                    </MenuItem>
                    <MenuItem Header="_Motion and time">
                        <MenuItem Header="All _paths..." Tag="Paths" Click="ExportResourceTypeMenuItem_Click"/>
                        <MenuItem Header="All _timelines..." Tag="Timelines" Click="ExportResourceTypeMenuItem_Click"/>
                        <MenuItem Header="All _sequences..." Tag="Sequences" Click="ExportResourceTypeMenuItem_Click"/>
                        <MenuItem Header="All _animation curves..." Tag="AnimationCurves" Click="ExportResourceTypeMenuItem_Click"/>
                    </MenuItem>
                    <MenuItem Header="_Rendering and effects">
                        <MenuItem Header="All _shaders..." Tag="Shaders" Click="ExportResourceTypeMenuItem_Click"/>
                        <MenuItem Header="All _particle systems..." Tag="ParticleSystems" Click="ExportResourceTypeMenuItem_Click"/>
                        <MenuItem Header="All particle _emitters..." Tag="ParticleSystemEmitters" Click="ExportResourceTypeMenuItem_Click"/>
                        <MenuItem Header="All _filter effects..." Tag="FilterEffects" Click="ExportResourceTypeMenuItem_Click"/>
                        <MenuItem Header="All texture _groups..." Tag="TextureGroups" Click="ExportResourceTypeMenuItem_Click"/>
                    </MenuItem>
                    <MenuItem Header="_Metadata">
                        <MenuItem Header="All _extensions..." Tag="Extensions" Click="ExportResourceTypeMenuItem_Click"/>
                        <MenuItem Header="All _strings..." Tag="Strings" Click="ExportResourceTypeMenuItem_Click"/>
                        <MenuItem Header="All _functions..." Tag="Functions" Click="ExportResourceTypeMenuItem_Click"/>
                        <MenuItem Header="All _variables..." Tag="Variables" Click="ExportResourceTypeMenuItem_Click"/>
                    </MenuItem>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Export _defaults..." Click="Settings_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem x:Name="LineNumbersCheckBox" Header="Show _line numbers" IsCheckable="True" IsChecked="True"
                          Checked="CodeViewOption_Changed" Unchecked="CodeViewOption_Changed"/>
                <MenuItem x:Name="WordWrapCheckBox" Header="_Word wrap" IsCheckable="True"
                          Checked="CodeViewOption_Changed" Unchecked="CodeViewOption_Changed"/>
                <Separator/>
                <MenuItem Header="Resource _preview" Tag="Preview" Click="ViewTab_Click"/>
                <MenuItem Header="_GML" Tag="GML" Click="ViewTab_Click"/>
                <MenuItem Header="VM _assembly" Tag="Assembly" Click="ViewTab_Click"/>
                <MenuItem Header="_Details" Tag="Details" Click="ViewTab_Click"/>
                <MenuItem Header="_Relationships" Tag="Relationships" Click="ViewTab_Click"/>
                <MenuItem Header="_Search" Tag="Search" Click="ViewTab_Click"/>
                <MenuItem Header="Activity _log" Tag="Activity" Click="ViewTab_Click"/>
                <Separator/>
                <MenuItem Header="_Refresh current preview" InputGestureText="F5" Click="RefreshCurrentPreview_Click"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="Search _all code..." InputGestureText="Ctrl+F" Click="ShowSearchTab_Click"/>
                <MenuItem x:Name="AnalyzeSelectedMenuItem" Header="Analyze selected _relationships" IsEnabled="False" Click="AnalyzeSelectedRelationships_Click"/>
                <MenuItem x:Name="UnusedCandidatesMenuItem" Header="Find _unused-resource candidates" IsEnabled="False" Click="AnalyzeUnusedResources_Click"/>
                <Separator/>
                <MenuItem x:Name="CopyDiagnosticButton" Header="Copy _diagnostic report" IsEnabled="False" Click="CopyDiagnosticButton_Click"/>
                <MenuItem Header="Open _logs folder" Click="OpenLogs_Click"/>
                <Separator/>
                <MenuItem Header="_Settings..." Click="Settings_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About SplitGM" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <Border Grid.Row="1" Padding="20,16" Background="#0E141D"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="SplitGM-VM Decompiler" FontSize="26" FontWeight="Bold"/>
                    <TextBlock Text="Read-only GameMaker resource viewer • VM decompiler • full extraction • project reconstruction"
                               Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Padding="11,6" Margin="0,0,10,0" Background="#19243A"
                            BorderBrush="{StaticResource Accent2Brush}" BorderThickness="1">
                        <TextBlock Text="v0.4.0 RELATIONSHIP NAVIGATOR" Foreground="{StaticResource AccentBrush}"
                                   FontWeight="Bold"/>
                    </Border>
                    <TextBlock x:Name="CompatibilityBadge" Text="NO GAME LOADED"
                               VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}"
                               FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>



        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" MinWidth="240"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="600"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="14,12,14,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RESOURCE TREE" FontWeight="Bold" Foreground="{StaticResource Accent2Brush}"/>
                        <TextBlock x:Name="ResourceTreeCountText" Grid.Column="1" Foreground="{StaticResource MutedTextBrush}"/>
                    </Grid>
                    <Grid Grid.Row="1" Margin="10,0,10,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ResourceFilterTextBox" Padding="8,5"
                                 ToolTip="Filter code and resource names. Press Enter or use Filter."
                                 KeyDown="ResourceFilterTextBox_KeyDown"/>
                        <Button Grid.Column="1" Content="Filter" Padding="10,5" Margin="6,0,4,0"
                                Click="FilterResourcesButton_Click"/>
                        <Button Grid.Column="2" Content="×" Padding="10,5" Margin="0"
                                ToolTip="Clear resource filter" Click="ClearResourceFilterButton_Click"/>
                    </Grid>
                    <TreeView x:Name="ResourceTree" Grid.Row="2" Margin="6,0,6,8"
                              SelectedItemChanged="ResourceTree_SelectedItemChanged"
                              MouseDoubleClick="ResourceTree_MouseDoubleClick"
                              TreeViewItem.Expanded="ResourceTreeItem_Expanded">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type local:ExplorerNode}" ItemsSource="{Binding Children}">
                                <Grid Margin="2,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Icon}" Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CountText}" Margin="8,0,4,0"
                                               Foreground="{StaticResource MutedTextBrush}"/>
                                </Grid>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="Transparent" ResizeDirection="Columns"/>

            <Border Grid.Column="2" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Padding="14,10" Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel>
                                <TextBlock x:Name="CurrentItemTitle" Text="Welcome to SplitGM v0.4.0"
                                           FontSize="17" FontWeight="Bold"/>
                                <TextBlock x:Name="CurrentItemSubtitle"
                                           Text="Open a GameMaker game to browse every recoverable resource."
                                           Margin="0,3,0,0" Foreground="{StaticResource MutedTextBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="8">
                        <TabItem x:Name="PreviewTab" Header="Resource Preview">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="3*"/>
                                    <RowDefinition Height="2*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Padding="8" Background="#0D131D"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="PreviewStatusText" Text="Select a resource to preview it."
                                                   VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}"/>
                                        <StackPanel x:Name="SpriteControlsPanel" Grid.Column="1" Orientation="Horizontal"
                                                    Visibility="Collapsed">
                                            <Button Content="◀" Padding="10,5" ToolTip="Previous frame" Click="PreviousFrameButton_Click"/>
                                            <Button x:Name="SpritePlayButton" Content="Play" Padding="12,5" Click="SpritePlayButton_Click"/>
                                            <Button Content="▶" Padding="10,5" ToolTip="Next frame" Click="NextFrameButton_Click"/>
                                            <TextBlock x:Name="SpriteFrameText" Margin="6,0,14,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel x:Name="AudioControlsPanel" Grid.Column="2" Orientation="Horizontal"
                                                    Visibility="Collapsed">
                                            <Button x:Name="PlayAudioButton" Content="Play audio" Padding="12,5" Click="PlayAudioButton_Click"/>
                                            <Button Content="Stop" Padding="12,5" Click="StopAudioButton_Click"/>
                                            <Button x:Name="ExportAudioGroupButton" Content="Export audio group..." Padding="12,5"
                                                    Visibility="Collapsed" Click="ExportAudioGroupButton_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1" Margin="0,8,0,8" Background="{StaticResource EditorBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <ScrollViewer x:Name="PreviewImageScrollViewer" HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto" Background="#06090E">
                                            <Grid MinWidth="320" MinHeight="220">
                                                <Image x:Name="PreviewImage" Stretch="None" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                <TextBlock x:Name="PreviewEmptyText" Text="No graphical preview is available for this resource."
                                                           Foreground="{StaticResource MutedTextBrush}" FontStyle="Italic"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </ScrollViewer>
                                        <avalonEdit:TextEditor x:Name="ResourceTextViewer" Visibility="Collapsed"
                                                               Background="{StaticResource EditorBrush}"
                                                               Foreground="{StaticResource TextBrush}"
                                                               HorizontalScrollBarVisibility="Auto"
                                                               VerticalScrollBarVisibility="Auto"/>
                                    </Grid>
                                </Border>

                                <TabControl x:Name="PreviewInformationTabs" Grid.Row="2">
                                    <TabItem Header="Properties">
                                        <TextBox x:Name="PreviewPropertiesTextBox" IsReadOnly="True" AcceptsReturn="True"
                                                 TextWrapping="NoWrap" BorderThickness="0"
                                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                                 Background="{StaticResource EditorBrush}"/>
                                    </TabItem>
                                    <TabItem x:Name="ObjectEventsTab" Header="Object Events" Visibility="Collapsed">
                                        <DataGrid x:Name="ObjectEventsGrid" MouseDoubleClick="ObjectEventsGrid_MouseDoubleClick">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Event" Binding="{Binding EventType}" Width="150"/>
                                                <DataGridTextColumn Header="Subtype" Binding="{Binding Subtype}" Width="90"/>
                                                <DataGridTextColumn Header="Code entry" Binding="{Binding CodeName}" Width="3*"/>
                                                <DataGridTextColumn Header="Actions" Binding="{Binding ActionCount}" Width="80"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem x:Name="RoomLayersTab" Header="Room Layers" Visibility="Collapsed">
                                        <DataGrid x:Name="RoomLayersGrid">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="48"/>
                                                <DataGridTextColumn Header="Layer" Binding="{Binding Name}" Width="2*"/>
                                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="120"/>
                                                <DataGridTextColumn Header="Depth" Binding="{Binding Depth}" Width="80"/>
                                                <DataGridCheckBoxColumn Header="Visible" Binding="{Binding Visible}" Width="70"/>
                                                <DataGridTextColumn Header="Items" Binding="{Binding ItemCount}" Width="70"/>
                                                <DataGridTextColumn Header="X" Binding="{Binding XOffset}" Width="70"/>
                                                <DataGridTextColumn Header="Y" Binding="{Binding YOffset}" Width="70"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem x:Name="RoomInstancesTab" Header="Room Instances" Visibility="Collapsed">
                                        <DataGrid x:Name="RoomInstancesGrid" MouseDoubleClick="RoomInstancesGrid_MouseDoubleClick">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="ID" Binding="{Binding InstanceId}" Width="85"/>
                                                <DataGridTextColumn Header="Object" Binding="{Binding ObjectName}" Width="2*"/>
                                                <DataGridTextColumn Header="Layer" Binding="{Binding LayerName}" Width="*"/>
                                                <DataGridTextColumn Header="X" Binding="{Binding X}" Width="65"/>
                                                <DataGridTextColumn Header="Y" Binding="{Binding Y}" Width="65"/>
                                                <DataGridTextColumn Header="Scale X" Binding="{Binding ScaleX}" Width="75"/>
                                                <DataGridTextColumn Header="Scale Y" Binding="{Binding ScaleY}" Width="75"/>
                                                <DataGridTextColumn Header="Rotation" Binding="{Binding Rotation}" Width="80"/>
                                                <DataGridTextColumn Header="Sprite" Binding="{Binding SpriteName}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem x:Name="RoomTilesTab" Header="Room Tiles" Visibility="Collapsed">
                                        <DataGrid x:Name="RoomTilesGrid">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="ID" Binding="{Binding InstanceId}" Width="85"/>
                                                <DataGridTextColumn Header="Asset" Binding="{Binding AssetName}" Width="2*"/>
                                                <DataGridTextColumn Header="Layer" Binding="{Binding LayerName}" Width="*"/>
                                                <DataGridTextColumn Header="X" Binding="{Binding X}" Width="65"/>
                                                <DataGridTextColumn Header="Y" Binding="{Binding Y}" Width="65"/>
                                                <DataGridTextColumn Header="Source X" Binding="{Binding SourceX}" Width="80"/>
                                                <DataGridTextColumn Header="Source Y" Binding="{Binding SourceY}" Width="80"/>
                                                <DataGridTextColumn Header="Width" Binding="{Binding Width}" Width="70"/>
                                                <DataGridTextColumn Header="Height" Binding="{Binding Height}" Width="70"/>
                                                <DataGridTextColumn Header="Depth" Binding="{Binding Depth}" Width="70"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                </TabControl>
                            </Grid>
                        </TabItem>
                        <TabItem x:Name="GmlTab" Header="GML">
                            <avalonEdit:TextEditor x:Name="GmlViewer" IsReadOnly="True" BorderThickness="0"
                                                   Background="{StaticResource EditorBrush}" Foreground="{StaticResource TextBrush}"
                                                   VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                        </TabItem>
                        <TabItem x:Name="AssemblyTab" Header="VM Assembly">
                            <avalonEdit:TextEditor x:Name="AssemblyViewer" IsReadOnly="True" BorderThickness="0"
                                                   Background="{StaticResource EditorBrush}" Foreground="{StaticResource TextBrush}"
                                                   VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                        </TabItem>
                        <TabItem x:Name="DetailsTab" Header="Details">
                            <TextBox x:Name="DetailsTextBox" IsReadOnly="True" AcceptsReturn="True"
                                     TextWrapping="NoWrap" BorderThickness="0"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     Background="{StaticResource EditorBrush}"/>
                        </TabItem>
                        <TabItem x:Name="RelationshipsTab" Header="Relationships">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="150"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Relationship and reference analysis" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="Analyze selection" Click="AnalyzeSelectedRelationships_Click"/>
                                    <Button Grid.Column="2" Content="Unused candidates" Margin="0" Click="AnalyzeUnusedResources_Click"/>
                                </Grid>
                                <TextBox x:Name="RelationshipSummaryTextBox" Grid.Row="1" IsReadOnly="True" AcceptsReturn="True"
                                         TextWrapping="Wrap" Margin="0,8,0,8" VerticalScrollBarVisibility="Auto"
                                         Background="{StaticResource EditorBrush}"/>
                                <DataGrid x:Name="RelationshipGrid" Grid.Row="2" MouseDoubleClick="RelationshipGrid_MouseDoubleClick">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Relationship" Binding="{Binding Relationship}" Width="170"/>
                                        <DataGridTextColumn Header="Target type" Binding="{Binding TargetType}" Width="130"/>
                                        <DataGridTextColumn Header="Target" Binding="{Binding TargetName}" Width="2*"/>
                                        <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="3*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>
                        <TabItem x:Name="SearchTab" Header="Search All Code">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CodeSearchTextBox" Padding="9,6"
                                             ToolTip="Search decompiled GML, VM assembly, and code-entry names."
                                             KeyDown="CodeSearchTextBox_KeyDown"/>
                                    <Button x:Name="SearchButton" Grid.Column="1" Content="Search" IsEnabled="False"
                                            Margin="8,0,0,0" Click="SearchButton_Click"/>
                                </Grid>
                                <TextBlock x:Name="SearchSummaryText" Grid.Row="1"
                                           Text="Search results will appear below. Double-click a result to open its code entry."
                                           Margin="2,8,0,8" Foreground="{StaticResource MutedTextBrush}"/>
                                <DataGrid x:Name="SearchResultsGrid" Grid.Row="2"
                                          MouseDoubleClick="SearchResultsGrid_MouseDoubleClick" AlternationCount="2">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Code entry" Binding="{Binding CodeName}" Width="2*"/>
                                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120"/>
                                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="85"/>
                                        <DataGridTextColumn Header="Line" Binding="{Binding LineNumber}" Width="65"/>
                                        <DataGridTextColumn Header="Match" Binding="{Binding Snippet}" Width="3*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>
                        <TabItem x:Name="ActivityTab" Header="Activity Log">
                            <TextBox x:Name="LogTextBox" IsReadOnly="True" AcceptsReturn="True"
                                     TextWrapping="NoWrap" BorderThickness="0"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     Background="{StaticResource EditorBrush}"/>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Padding="12,8" Background="#0E141D"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="StatusTextBlock" Text="Ready. Open or drop a GameMaker file."
                               VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusDetailTextBlock" Margin="12,0,0,0"
                               VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
                <ProgressBar x:Name="ProgressBar" Grid.Column="1" Height="8" Margin="16,0"
                             VerticalAlignment="Center" Minimum="0" Maximum="100" Value="0"
                             Foreground="{StaticResource AccentBrush}" Background="#080B11"/>
                <Button x:Name="CancelButton" Grid.Column="2" Content="Cancel" Padding="12,5"
                        IsEnabled="False" Margin="0" Click="CancelButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
