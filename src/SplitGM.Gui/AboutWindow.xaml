<Window x:Class="SplitGM.Gui.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About SplitGM-VM Decompiler"
        Width="720" Height="560"
        MinWidth="620" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Padding="18" Background="{StaticResource PanelAltBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="76" Height="76" CornerRadius="12"
                        Background="#1B2B3E" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                    <TextBlock Text="SG" FontSize="30" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="SplitGM-VM Decompiler" FontSize="24" FontWeight="Bold"/>
                    <TextBlock x:Name="VersionText" Margin="0,5,0,0"
                               Foreground="{StaticResource AccentBrush}" FontSize="14"/>
                    <TextBlock Text="Read-only GameMaker VM decompiler, resource viewer, relationship navigator, extractor, and project-reconstruction studio."
                               Margin="0,8,0,0" TextWrapping="Wrap"
                               Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="0,14,0,14">
            <TabItem Header="Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="Purpose" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Accent2Brush}"/>
                        <TextBlock Margin="0,6,0,16" TextWrapping="Wrap"
                                   Text="SplitGM opens supported GameMaker data files and Windows executables, reconstructs readable GML from VM bytecode, previews recoverable game resources, analyzes relationships, and exports a structured reconstruction without modifying the original game."/>
                        <TextBlock Text="Read-only design" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Accent2Brush}"/>
                        <TextBlock Margin="0,6,0,16" TextWrapping="Wrap"
                                   Text="SplitGM does not import, patch, compile, replace, or save changes back into data.win. Decompiled GML is reconstructed source and may differ from the original project source."/>
                        <TextBlock Text="Runtime" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Accent2Brush}"/>
                        <TextBlock x:Name="RuntimeText" Margin="0,6,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Components">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="UndertaleModLib" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Accent2Brush}"/>
                        <TextBlock Margin="0,6,0,16" TextWrapping="Wrap"
                                   Text="Provides GameMaker data parsing, resource models, version detection, texture and audio access, and VM disassembly."/>
                        <TextBlock Text="Underanalyzer" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Accent2Brush}"/>
                        <TextBlock Margin="0,6,0,16" TextWrapping="Wrap"
                                   Text="Provides GameMaker VM control-flow analysis and high-level GML reconstruction."/>
                        <TextBlock Text="SplitGM" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Accent2Brush}"/>
                        <TextBlock Margin="0,6,0,0" TextWrapping="Wrap"
                                   Text="Adds the read-only desktop interface, resource previews, safe extraction, relationship navigation, progress reporting, settings, diagnostics, and reconstructed-project organization."/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="License">
                <Grid Margin="12">
                    <TextBox IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                             Text="SplitGM-VM Decompiler is licensed under the GNU General Public License version 3 (GPL-3.0).&#x0a;&#x0a;UndertaleModTool and UndertaleModLib are GPL-3.0 software. Underanalyzer is distributed under its own stated license. The complete source package includes LICENSE.txt and THIRD-PARTY-NOTICES.md.&#x0a;&#x0a;GameMaker, UNDERTALE, and DELTARUNE are properties of their respective owners. SplitGM is an independent reverse-engineering and archival tool and is not affiliated with those owners."/>
                </Grid>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="2" LastChildFill="False">
            <Button Content="Open application folder" Click="OpenApplicationFolder_Click"/>
            <Button Content="Open license files" Click="OpenLicenseFiles_Click"/>
            <Button Content="Close" Margin="0" DockPanel.Dock="Right" IsDefault="True" Click="Close_Click"/>
        </DockPanel>
    </Grid>
</Window>
