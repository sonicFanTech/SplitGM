<Window x:Class="SplitGM.Gui.ConnectedCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connected GML Code" Width="820" Height="520" MinWidth="680" MinHeight="400"
        WindowStartupLocation="CenterOwner" Background="{StaticResource WindowBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel Margin="0,0,0,12">
            <TextBlock x:Name="TitleText" Text="Connected GML Code" FontSize="22" FontWeight="Bold"/>
            <TextBlock x:Name="SubtitleText" Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
        </StackPanel>
        <DataGrid x:Name="CodeGrid" Grid.Row="1" MouseDoubleClick="CodeGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Relationship" Binding="{Binding Relationship}" Width="170"/>
                <DataGridTextColumn Header="Code entry" Binding="{Binding CodeName}" Width="2*"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="130"/>
                <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Text="Double-click a row, or select it and choose Open Code." VerticalAlignment="Center"
                       Foreground="{StaticResource MutedTextBrush}"/>
            <Button Grid.Column="1" Content="Cancel" Click="Cancel_Click"/>
            <Button Grid.Column="2" Content="Open Code" Margin="0" Background="#155A74"
                    BorderBrush="{StaticResource AccentBrush}" Click="Open_Click"/>
        </Grid>
    </Grid>
</Window>
